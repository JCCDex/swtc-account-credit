{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "es2015"
    ],
    "outDir": "./lib",
    "rootDir": "./src",
    "moduleResolution": "node",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "declaration": true,
    "experimentalDecorators": true,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": [
    "./src/**/*.ts"
  ]
}